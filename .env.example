# API Configuration - these will be loaded automatically
EXPO_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
EXPO_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent
EXPO_PUBLIC_LANGGRAPH_API_KEY=your-api-key-here

# Note: Use EXPO_PUBLIC_ prefix for client-side access in Expo
# Without the prefix, variables are only available server-side
